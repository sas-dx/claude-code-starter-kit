{
  "_comment": "これはsettings.jsonの設定項目の参考例です。このファイル自体はClaude Codeが読み込むものではありません。実際の設定は .claude/settings.json または ~/.claude/settings.json に記述してください。",

  "権限設定": {
    "permissions": {
      "allow": [
        "Bash",
        "Read",
        "Edit",
        "Write",
        "Glob",
        "Grep"
      ],
      "deny": [
        "Bash(rm -rf *)",
        "Bash(sudo *)",
        "Bash(curl * | bash)",
        "Bash(wget * | bash)"
      ]
    }
  },

  "環境変数": {
    "env": {
      "NODE_ENV": "development",
      "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
    }
  },

  "使用禁止ツール": {
    "disallowedTools": [
      "Agent(Explore)"
    ]
  },

  "フック設定": {
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Edit|Write",
          "hooks": [
            {
              "type": "command",
              "command": "./.claude/hooks/protect-files.sh",
              "timeout": 30
            }
          ]
        }
      ],
      "PostToolUse": [
        {
          "matcher": "Edit|Write",
          "hooks": [
            {
              "type": "command",
              "command": "./.claude/hooks/auto-format.sh"
            }
          ]
        }
      ],
      "SessionStart": [
        {
          "matcher": "startup",
          "hooks": [
            {
              "type": "command",
              "command": "./.claude/hooks/setup-env.sh"
            }
          ]
        }
      ]
    }
  },

  "サンドボックス設定": {
    "sandbox": {
      "enabled": true,
      "pathPrefixes": [
        "/home/user/project"
      ]
    }
  },

  "Agent Teams 設定": {
    "teammateMode": "in-process"
  }
}
